{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "identifier": "com.root.aurestream",
  "productName": "aurestream",
  "bundle": {
    "targets": [
      "deb",
      "rpm",
      "appimage"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "resources/main.desktop",
        "files": {
          "/usr/lib/AureStream/aurestream-tun-helper": "resources/linux/aurestream-tun-helper",
          "/usr/share/polkit-1/actions/com.root.aurestream.policy": "resources/linux/com.root.aurestream.policy",
          "/etc/polkit-1/rules.d/49-aurestream.rules": "resources/linux/49-aurestream.rules"
        },
        "postInstallScript": "resources/linux/deb-postinst.sh",
        "postRemoveScript": "resources/linux/deb-postrm.sh"
      },
      "rpm": {
        "desktopTemplate": "resources/main.desktop",
        "files": {
          "/usr/lib/AureStream/aurestream-tun-helper": "resources/linux/aurestream-tun-helper",
          "/usr/share/polkit-1/actions/com.root.aurestream.policy": "resources/linux/com.root.aurestream.policy",
          "/etc/polkit-1/rules.d/49-aurestream.rules": "resources/linux/49-aurestream.rules"
        }
      }
    }
  }
}
