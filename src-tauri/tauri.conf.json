{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aurestream",
  "version": "0.2.2",
  "identifier": "com.root.aurestream",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AureStream",
        "width": 1050,
        "height": 780,
        "minWidth": 960,
        "minHeight": 750
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/aurestream-core"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "aurestream"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/BadKid90s/AureStream/releases/latest/download/latest.json"
      ],
      "dangerouslyInsecure": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCMjBBNTE3QzYxRjZBN0YKUldSL2FoL0dGNlVnaTVHZjBSdE5GVHY5ekFqUGRQTVZHK1dVT2pMM3VraFhVUFBkL0NET01ncmMK"
    }
  }
}
