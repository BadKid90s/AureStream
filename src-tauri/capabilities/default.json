{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-set-theme",
    "core:window:allow-start-dragging",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "store:default",
    "os:default",
    "os:allow-locale",
    "os:allow-os-type",
    "shell:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/aurestream-core",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:allow-open",
    "http:default",
    "http:allow-fetch",
    "http:allow-fetch-cancel",
    "http:allow-fetch-read-body",
    "fs:default",
    "fs:allow-app-write",
    "fs:allow-app-read",
    "process:default",
    "process:allow-exit",
    "process:allow-restart",
    "dialog:default",
    "log:default"
  ]
}
