{
  "name": "aureproxy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "_说明": "_ 开头的顶层字段不参与运行逻辑，仅占位说明；pnpm / npm / yarn 会静默忽略不识别的键（若你的工具报错，可删去 _ 前缀字段或改为 readme）。",
  "_scripts_zh": {
    "dev": "纯前端调试：启动 Vite 开发服务器（默认 http://localhost:5173）。",
    "dev:desktop": "桌面调试：启动 Tauri（会拉起 Vite 与原生壳）。",
    "server": "等同于 dev:desktop（历史别名）。",
    "build": "生产构建前端：先做 TypeScript 检查（src），再通过 Vite 打 dist。",
    "build:web": "仅 Vite 构建（跳过 tsc），应急使用；正式发布请用 build。",
    "typecheck": "仅运行前端 src 目录的 TS 校验。",
    "typecheck:node": "校验 vite.config.ts（tsconfig.node.json）。",
    "preview": "本地预览 vite build 后的静态产物。",
    "tauri": "透传执行 Tauri CLI，例如 npm run tauri -- info。",
    "tauri:dev": "同上 dev:desktop。",
    "tauri:build": "编译与打包桌面安装包（Rust + 前端）。"
  },
  "scripts": {
    "dev": "vite",
    "dev:desktop": "tauri dev",
    "server": "tauri dev",
    "build": "npm run typecheck && vite build",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:win": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:win-arm64": "tauri build --target aarch64-pc-windows-msvc",
    "mihomo:download": "bash scripts/download-mihomo.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tauri-plugin-mihomo-api": "github:clash-verge-rev/tauri-plugin-mihomo",
    "zustand": "^5.0.13"
  },
  "_devDependencies_zh": {
    "@types/react": "React 组件与 JSX 的类型。",
    "typescript": "tsc / 编辑器 IntelliSense。"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.6"
  }
